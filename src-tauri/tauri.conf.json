{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocLinker",
  "version": "0.1.0",
  "identifier": "com.doclinker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DocLinker",
        "width": 1080,
        "height": 680,
        "minWidth": 920,
        "minHeight": 560,
        "resizable": true,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "focus": true,
        "shadow": false,
        "skipTaskbar": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
